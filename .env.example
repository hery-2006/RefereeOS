# RefereeOS local configuration
#
# Daytona SDK reads DAYTONA_API_KEY, DAYTONA_API_URL, and DAYTONA_TARGET.
# OpenAI is used inside Daytona to interpret the reproducibility receipt.

DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=
# Keep false unless you explicitly want to send your local OpenAI key into Daytona.
REFEREEOS_PASS_OPENAI_KEY_TO_DAYTONA=false

REFEREEOS_ALLOW_LOCAL_REPRO_FALLBACK=true
REFEREEOS_OUTPUT_DIR=outputs/runs
