# RefereeOS local configuration
#
# Daytona SDK reads DAYTONA_API_KEY, DAYTONA_API_URL, and DAYTONA_TARGET.
# Gemini Pro 3.1 access is expected to be sponsor-provided inside Daytona,
# but these variables can be used for local/sandbox pass-through if needed.

DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_API_KEY=
GOOGLE_API_KEY=

OPENAI_API_KEY=
REFEREEOS_ALLOW_LOCAL_REPRO_FALLBACK=true
REFEREEOS_OUTPUT_DIR=outputs/runs
